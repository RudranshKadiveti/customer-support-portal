# ─── SECRET KEY (generate a strong random value for production) ───
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_256_BIT_HEX_STRING
JWT_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_256_BIT_HEX_STRING

# ─── Database (MySQL – leave blank to fallback to SQLite for dev) ───
MYSQLHOST=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQLPORT=3306

# ─── CORS Origin (your frontend URL) ───
CORS_ORIGIN=http://localhost:3001

# ─── Rate Limiting ───
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=60/minute
RATE_LIMIT_TICKET=10/minute

# ─── HTTPS Enforcement (set to 1 in production behind TLS) ───
ENFORCE_HTTPS=0
